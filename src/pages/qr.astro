---
import Layout from '../layouts/Layout.astro';
import QRPoster from '../components/QRPoster';
---

<Layout title="Póster QR">
  <h1>Póster QR</h1>
  <p class="page-intro">
    Descarga e imprime este póster para colocarlo en escuelas, mercados y espacios comunitarios.
  </p>
  <QRPoster client:load />
</Layout>

<style>
  h1 {
    font-size: 1.5rem;
    margin-bottom: var(--space-1);
  }

  .page-intro {
    color: var(--text-muted);
    margin-bottom: var(--space-5);
  }
</style>

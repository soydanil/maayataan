---
import Layout from '../layouts/Layout.astro';
import ContributionForm from '../components/ContributionForm';
---

<Layout title="Contribuir">
  <section class="contribute-header">
    <h1 class="contribute-maya">Ts'áaj a T'aan</h1>
    <p class="contribute-es">Comparte tu voz</p>
    <p class="contribute-intro">
      Cada palabra que compartes ayuda a preservar y fortalecer el maya yucateco.
    </p>
  </section>

  <ContributionForm client:load />
</Layout>

<style>
  .contribute-header {
    margin-bottom: var(--space-4);
  }

  .contribute-maya {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
  }

  .contribute-es {
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-bottom: var(--space-3);
  }

  .contribute-intro {
    color: var(--text-muted);
    font-size: 0.95rem;
  }
</style>

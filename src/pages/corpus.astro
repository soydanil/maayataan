---
import Layout from '../layouts/Layout.astro';
import DatasetBrowser from '../components/DatasetBrowser';
---

<Layout title="Corpus">
  <h1>Corpus maya yucateco</h1>
  <p class="page-intro">
    Explora las contribuciones aprobadas de la comunidad.
  </p>
  <DatasetBrowser client:load />
</Layout>

<style>
  h1 {
    font-size: 1.5rem;
    margin-bottom: var(--space-1);
  }

  .page-intro {
    color: var(--text-muted);
    margin-bottom: var(--space-5);
  }
</style>
